<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Currency Converter</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      background: #fff;
      padding: 24px;
      color: #111;
    }
    .converter-box {
      max-width: 380px;
      margin: 0 auto;
      border: 3px solid #000;
      padding: 18px;
      box-sizing: border-box;
    }
    .converter-box h1 {
      text-align: center;
      color: #0b36b3;
      margin: 0 0 12px 0;
      font-size: 22px;
    }
    label {
      display: block;
      margin: 12px 0 6px 0;
      font-weight: 600;
    }
    input[type="number"],
    select {
      width: 100%;
      padding: 8px 10px;
      font-size: 16px;
      border: 3px solid #000;
      box-sizing: border-box;
    }
    .result-pill {
      margin-top: 14px;
      background: #063bff;
      color: #fff;
      padding: 10px;
      border-radius: 999px;
      text-align: center;
      font-size: 20px;
      font-weight: 700;
      box-sizing: border-box;
    }
  </style>
</head>
<body>
  <div class="converter-box" role="main">
    <h1>Currency Converter</h1>

    <label for="amount">Amount:</label>
    <input id="amount" type="number" value="11" min="0" step="0.01" onchange="convertCurrency()" />

    <label for="fromCurrency">From:</label>
    <select id="fromCurrency" onchange="convertCurrency()">
      <option value="USD">USD</option>
      <option value="EUR">EUR</option>
      <option value="GBP">GBP</option>
      <option value="INR">INR</option>
    </select>

    <label for="toCurrency">To:</label>
    <select id="toCurrency" onchange="convertCurrency()">
      <option value="INR">INR</option>
      <option value="USD">USD</option>
      <option value="EUR">EUR</option>
      <option value="GBP">GBP</option>
    </select>

    <div id="result" class="result-pill" aria-live="polite">Amount = --</div>
  </div>

  <script>
    var rates = {
      USD: 1,
      EUR: 0.92,
      GBP: 0.79,
      INR: 83
    };

    function convertCurrency() {
      var amountEl = document.getElementById('amount');
      var fromEl = document.getElementById('fromCurrency');
      var toEl = document.getElementById('toCurrency');
      var resultEl = document.getElementById('result');

      var amount = parseFloat(amountEl.value);
      var from = fromEl.value;
      var to = toEl.value;

      if (!isFinite(amount) || amount < 0) {
        resultEl.textContent = 'Please enter a valid amount';
        return;
      }

      var converted = amount * (rates[to] / rates[from]);
      var formatted = converted.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      resultEl.textContent = 'Amount = ' + formatted + ' ' + to;
    }

    window.onload = function() {
      convertCurrency();
    };
  </script>
</body>
</html>
